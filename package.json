{
  "name": "officeecho",
  "version": "1.0.0",
  "description": "辅导员数字人系统",
  "main": "electron/main.js",
  "scripts": {
    "dev:visitor": "concurrently \"vite --config vite.config.elderly.ts\" \"wait-on http://localhost:3000 && electron .\"",
    "dev:admin": "vite --config vite.config.family.ts",
    "build:visitor": "tsc && vite build --config vite.config.elderly.ts",
    "build:admin": "tsc && vite build --config vite.config.family.ts",
    "build:electron": "npm run build:visitor && electron-builder",
    "electron": "electron .",
    "preview": "vite preview",
    "start:all": "./run_officeecho.sh"
  },
  "keywords": [
    "office",
    "digital-avatar",
    "reception",
    "customer-service",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "lucide-react": "^0.294.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.10.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.9.3",
    "vite": "^5.0.8",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.officeecho.app",
    "productName": "OfficeEcho",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      {
        "from": "dist/elderly",
        "to": ".",
        "filter": [
          "**/*"
        ]
      }
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png"
    }
  }
}
