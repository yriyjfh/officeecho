# ==================== OfficeEcho 配置文件示例 ====================
# 复制此文件为 .env 并填入实际值
# 注意：.env 文件不应提交到版本控制

# ==================== Fay 数字人配置 ====================
# Fay WebSocket 地址 (用于接收数字人消息)
VITE_FAY_WEBSOCKET_URL=ws://127.0.0.1:10002

# Fay HTTP API 地址 (用于获取聊天记录等)
VITE_FAY_HTTP_URL=http://127.0.0.1:5000

# 后端使用的 Fay HTTP 地址 (Python 环境变量)
FAY_HTTP_URL=http://127.0.0.1:5000

# ==================== Xmov SDK 配置 ====================
# 魔珐科技数字人 SDK 应用 ID
