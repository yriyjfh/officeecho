VITE_XMOV_APP_ID=de69895d17d947f59771b2b9aa992fb6

# 魔珐科技数字人 SDK 应用密钥
VITE_XMOV_APP_SECRET=fcee5eb510304b06b53f6831295095e6

# Xmov 网关服务器地址 (通常不需要修改)
